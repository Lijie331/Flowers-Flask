    {
      "id": 63,
      "chinese_name": "红唇卡特兰",
      "english_name": "ruby-lipped cattleya",
      "latin_name": "Cattleya labiata",
      "family": "兰科",
      "genus": "卡特兰属",
      "morphology": "多年生常绿附生草本植物。假鳞茎棍棒状，具2-3节，顶生叶片1-2枚，革质，长椭圆形。花单生或2-3朵成总状花序；花大，径10-20厘米，萼片和花瓣淡紫色，唇瓣大，喉部黄色有紫红色条纹，芳香。花期9-11月。",
      "habitat": "原产南美洲热带地区。附生于森林树木上，喜高温高湿的半阴环境。",
      "growth_habit": "花期9-11月。生长适温20-30℃。",
      "ornamental_value": "花大色艳，芳香馥郁，是重要的切花和盆花花卉，有\"兰花之王\"之称。",
      "care_methods": "用通透性好的附生基质栽培。浇水遵循见干见湿原则。",
      "flower_language": "成熟魅力、优雅、珍贵",
      "category_id": 63,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 64,
      "chinese_name": "暹罗郁金香",
      "english_name": "siam tulip",
      "latin_name": "Curcuma alismatifolia",
      "family": "姜科",
      "genus": "姜黄属",
      "morphology": "多年生草本植物，株高50-80厘米。叶片长椭圆形，绿色，基生。穗状花序顶生，苞片大，粉红色或白色，排列呈塔状；唇瓣颜色深。花期6-8月。",
      "habitat": "原产泰国和东南亚。喜高温高湿阳光充足的环境，不耐寒。",
      "growth_habit": "花期6-8月，果期7-9月。通过分株繁殖。",
      "ornamental_value": "花序美丽，苞片粉红或白色，适合盆栽或切花。",
      "care_methods": "用肥沃疏松的土壤栽培。生长期保持土壤湿润。冬季休眠期减少浇水。",
      "flower_language": "神秘、优雅、异国风情",
      "category_id": 64,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 65,
      "chinese_name": "银叶灌木",
      "english_name": "silverbush",
      "latin_name": "Convolvulus cneorum",
      "family": "旋花科",
      "genus": "旋花属",
      "morphology": "常绿灌木，株高60-100厘米。茎直立，密被银色绢毛。叶片披针形或线形，，银灰绿色，密被绢毛。花单生于枝顶或叶腋，花冠漏斗形，白色或粉红色，外部有银色绢毛。花期5-7月。",
      "habitat": "原产地中海地区。喜阳光充足，温暖干燥气候，耐热耐旱，适宜排水良好的土壤。",
      "growth_habit": "花期5-7月，果期6-8月。通过扦插或播种繁殖。",
      "ornamental_value": "全株银白色，花色淡雅，是良好的观叶和观花植物。",
      "care_methods": "用排水良好的土壤栽培。控制浇水，保持土壤干燥。",
      "flower_language": "神秘、优雅、珍贵",
      "category_id": 65,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 66,
      "chinese_name": "金鱼草",
      "english_name": "snapdragon",
      "latin_name": "Antirrhinum majus",
      "family": "玄参科",
      "genus": "金鱼草属",
      "morphology": "一年生或多年生草本植物，株高30-90厘米。茎直立。叶片长圆形或披针形，对生或上部互生。总状花序顶生；花冠二唇形，似龙口，张合有趣，有红、粉、黄、白、橙等色。花期5-10月。",
      "habitat": "原产地中海地区。喜阳光充足，凉爽气候，耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期5-10月，果期6-10月。播种繁殖。",
      "ornamental_value": "花型独特有趣，色彩丰富，是重要的花坛和切花材料。",
      "care_methods": "生长期保持土壤湿润。花后及时剪除残花，可延长花期。",
      "flower_language": "多才多艺、活泼、开朗",
      "category_id": 66,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 67,
      "chinese_name": "矛蓟",
      "english_name": "spear thistle",
      "latin_name": "Cirsium vulgare",
      "family": "菊科",
      "genus": "蓟属",
      "morphology": "二年生草本植物，株高50-150厘米。茎直立，有分枝，被刺状毛。叶片羽状深裂，裂片边缘有刺，两面被绒毛。头状花序大型，单生或成圆锥状；花紫红色，全部为管状花。花期6-8月。",
      "habitat": "原产欧亚大陆。喜阳光充足，耐寒耐旱，适应性强，常生于路边荒野。",
      "growth_habit": "花期6-8月，果期7-9月。自播繁殖能力强。",
      "ornamental_value": "花序紫红艳丽，是重要的蜜源植物，也可作为野花组合材料。",
      "care_methods": "管理粗放，适应性强。可适当浇水，无需特殊管理。",
      "flower_language": "独立、勇敢、防御",
      "category_id": 67,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 68,
      "chinese_name": "春番红花",
      "english_name": "spring crocus",
      "latin_name": "Crocus vernus",
      "family": "鸢尾科",
      "genus": "番红花属",
      "morphology": "多年生草本植物，株高10-20厘米。鳞茎球形，外被纤维状膜。叶片线形，基生，有白色纵条纹。花单生或2-3朵生于鳞茎顶端；花冠钟状或漏斗状，裂片6，有白、紫、黄等色，喉部常有斑纹。柱头橙红色。花期3-4月。",
      "habitat": "原产欧洲。喜阳光充足或半阴，耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期3-4月，果期5月。通过鳞茎分球繁殖。",
      "ornamental_value": "早春开花，是重要的早春球根花卉，也是著名的香料和药材。",
      "care_methods": "种植深度为鳞茎高度的2-3倍。生长期保持土壤湿润即可。",
      "flower_language": "青春、欢乐、喜悦",
      "category_id": 68,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 69,
      "chinese_name": "无茎龙胆",
      "english_name": "stemless gentian",
      "latin_name": "Gentiana acaulis",
      "family": "龙胆科",
      "genus": "龙胆属",
      "morphology": "多年生草本植物，株高5-10厘米。叶片基生，莲座状，椭圆形或披针形，革质，绿色。花单生，无茎，由基部抽出；花冠钟状，深蓝色，裂片5，裂片间有纵条纹。花期4-6月。",
      "habitat": "原产欧洲阿尔卑斯山脉。喜阳光充足，凉爽湿润气候，耐寒，适宜酸性排水良好的土壤。",
      "growth_habit": "花期4-6月，果期5-7月。通过分株或播种繁殖。",
      "ornamental_value": "花深蓝色，钟状艳丽，适合岩石园和高山植物园种植。",
      "care_methods": "用酸性排水良好的土壤栽培。保持土壤湿润但避免积水。",
      "flower_language": "努力、不屈、勇敢",
      "category_id": 69,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 70,
      "chinese_name": "向日葵",
      "english_name": "sunflower",
      "latin_name": "Helianthus annuus",
      "family": "菊科",
      "genus": "向日葵属",
      "morphology": "一年生草本植物，株高1-3米。茎直立，粗壮，被糙毛。叶片心形或卵圆形，边缘有锯齿。头状花序大型，单生茎顶；舌状花黄色，管状花紫褐色。瘦果倒卵形，灰白色或黑色。花期7-9月。",
      "habitat": "原产北美。喜阳光充足，耐热耐寒，对土壤要求不严。",
      "growth_habit": "花期7-9月，果期8-10月。通过种子繁殖。",
      "ornamental_value": "花序大而金黄，象征着阳光和活力，是重要的油料作物和观赏植物。",
      "care_methods": "生长期保持土壤湿润。播种直播，苗期注意防虫。",
      "flower_language": "阳光、忠诚、爱慕",
      "category_id": 70,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 71,
