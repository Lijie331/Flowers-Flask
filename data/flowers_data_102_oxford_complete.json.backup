    {
      "id": 21,
      "chinese_name": "射干",
      "english_name": "blackberry lily",
      "latin_name": "Belamcanda chinensis",
      "family": "鸢尾科",
      "genus": "射干属",
      "morphology": "多年生草本植物，株高50-100厘米。根茎横走。叶片剑形，基部套叠成茎状。花序顶生，疏散；花橙色，有红色斑点，6瓣。蒴果成熟时室背开裂，露出黑色种子如黑莓状。花期7-9月。",
      "habitat": "原产中国、日本和朝鲜。喜阳光充足，耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期7-9月，果期9-10月。种子黑色肾形，聚合成球状。",
      "ornamental_value": "花橙色有斑点，果实黑色别致，是良好的观赏花卉和药材。",
      "care_methods": "生长期保持土壤湿润。春季分株繁殖，播种需2-3年开花。",
      "flower_language": "诚实、果断、力量",
      "category_id": 21,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
