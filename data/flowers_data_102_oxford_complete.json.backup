    {
      "id": 44,
      "chinese_name": "贝母",
      "english_name": "fritillary",
      "latin_name": "Fritillaria verticillata",
      "family": "百合科",
      "genus": "贝母属",
      "morphology": "多年生草本植物，株高30-80厘米。鳞茎卵圆形，由2枚肥厚鳞片组成。茎直立，中空。叶片线形或披针形，3-7枚轮生于茎上。花单生或数朵成总状花序，下垂；花冠钟状，绿黄色或淡紫色，有格纹斑点。花期4-5月。",
      "habitat": "原产北半球温带地区。喜凉爽湿润阳光充足的环境，耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期4-5月，果期5-6月。鳞茎可入药，有清热润肺的功效。",
      "ornamental_value": "花型独特，钟状下垂，有格纹，是良好的观赏花卉和药材。",
      "care_methods": "种植深度为鳞茎高度的2-3倍。生长期保持土壤湿润，夏季注意排水。",
      "flower_language": "神秘、独特、个性",
      "category_id": 44,
