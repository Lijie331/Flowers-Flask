    {
      "id": 24,
      "chinese_name": "三角梅",
      "english_name": "bougainvillea",
      "latin_name": "Bougainvillea spectabilis",
      "family": "紫茉莉科",
      "genus": "叶子花属",
      "morphology": "攀援状灌木，枝具枝刺。叶片椭圆形或卵形，绿色。花小，常3朵簇生于苞片内；苞片大，色彩鲜艳，有紫、红、橙、白等色，形似花瓣。花期11月至次年6月。",
      "habitat": "原产南美洲。喜阳光充足，温暖湿润气候，耐热耐旱，不耐寒。",
      "growth_habit": "花期11月至次年6月，果期冬季。通过扦插或压条繁殖。",
      "ornamental_value": "苞片色彩鲜艳，花期长，是重要的攀援观赏植物。",
      "care_methods": "生长期保持土壤湿润。春季修剪促发新枝。花前增施磷钾肥。",
      "flower_language": "热情、活力、坚韧",
      "category_id": 24,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
