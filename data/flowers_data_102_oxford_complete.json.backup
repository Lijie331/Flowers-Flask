    {
      "id": 28,
      "chinese_name": "山茶花",
      "english_name": "camellia",
      "latin_name": "Camellia japonica",
      "family": "山茶科",
      "genus": "山茶属",
      "morphology": "常绿灌木或小乔木，株高2-10米。叶片革质，椭圆形，边缘有细锯齿，深绿色有光泽。花大，单生或簇生于枝顶，有红、粉、白等色，有单瓣和重瓣品种。花期12月至次年4月。",
      "habitat": "原产中国、日本和朝鲜。喜半阴温暖湿润环境，适宜酸性排水良好的土壤。",
      "growth_habit": "花期12月至次年4月，果期8-9月。喜酸性土壤，忌碱性。",
      "ornamental_value": "花大色艳，花期长，是中国传统名花，有\"花中娇客\"之称。",
      "care_methods": "生长期保持土壤湿润，忌积水。春季花后及时修剪，夏季遮阴。",
      "flower_language": "理想的爱、谦让、可爱",
      "category_id": 28,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
