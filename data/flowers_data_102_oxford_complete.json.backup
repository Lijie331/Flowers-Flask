      "genus": "距药姜属",
      "morphology": "多年生草本植物，株高60-90厘米。叶片披针形，绿色。穗状花序顶生，花黄色，唇瓣基部有红斑，花萼筒状。花期7-8月。",
      "habitat": "原产喜马拉雅地区。喜半阴湿润环境，适宜富含腐殖质的土壤。",
      "growth_habit": "花期7-8月，果期9-10月。通过分株繁殖。",
      "ornamental_value": "花黄色艳丽，适合林下或阴处种植，是良好的耐阴花卉。",
      "care_methods": "种植于半阴处，保持土壤湿润。冬季休眠期减少浇水。",
      "flower_language": "优雅、珍贵、神秘",
      "category_id": 32,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 33,
      "chinese_name": "铁线莲",
      "english_name": "clematis",
      "latin_name": "Clematis spp.",
      "family": "毛茛科",
      "genus": "铁线莲属",
      "morphology": "多年生攀援草本或木质藤本。茎攀援，节上有卷须。叶片对生，一至二回三出复叶。小花单生或成圆锥花序，花瓣4-8枚，有白、粉、蓝、紫等色。花期4-9月。",
      "habitat": "原产北半球温带地区。喜阳光充足，凉爽气候，忌酷热。",
      "growth_habit": "花期4-9月，果期6-11月。茎攀援生长，需搭设支架。",
      "ornamental_value": "花大色艳，品种繁多，有\"藤本皇后\"之称，是重要的垂直绿化材料。",
      "care_methods": "喜酸性土壤，种植时施足基肥。夏季注意遮阴降温。修剪因品种而异。",
      "flower_language": "精神之美、旅人的喜悦、智慧",
      "category_id": 33,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 34,
      "chinese_name": "款冬",
      "english_name": "colt's foot",
      "latin_name": "Tussilago farfara",
      "family": "菊科",
      "genus": "款冬属",
      "morphology": "多年生草本植物，株高10-30厘米。根茎横走。基生叶圆心形，边缘有波状齿，下面被白色绒毛，花后抽出花茎。头状花序单生，黄色，雌花舌状，两性花管状。花期早春。",
      "habitat": "原产欧亚大陆。喜凉爽湿润环境，耐寒，常生于河滩、溪边等湿润处。",
      "growth_habit": "花期2-4月，先花后叶。通过根茎和种子繁殖。",
      "ornamental_value": "早春开花，是重要的蜜源植物，也可作为地被植物栽培。",
      "care_methods": "管理粗放，适应性强。适当浇水即可，无需特殊管理。",
      "flower_language": "勇敢、坚强、克服困难",
      "category_id": 34,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 35,
      "chinese_name": "耧斗菜",
      "english_name": "columbine",
      "latin_name": "Aquilegia vulgaris",
      "family": "毛茛科",
      "genus": "耧斗菜属",
      "morphology": "多年生草本植物，株高40-80厘米。茎直立，有分枝。基生叶为二回三出复叶，小叶倒卵形。聚伞花序顶生；花下垂，花瓣5枚，有距，距长而弯，蓝紫色、粉色或白色。花期5-7月。",
      "habitat": "原产北半球温带地区。喜凉爽半阴环境，耐寒，适宜湿润肥沃的土壤。",
      "growth_habit": "花期5-7月，果期6-8月。通过播种或分株繁殖。",
      "ornamental_value": "花型独特，花瓣有长距，形如漏斗，色彩雅致，是良好的林下花卉。",
      "care_methods": "种植于半阴处，保持土壤湿润。花后收集种子适时播种。",
      "flower_language": "愚蠢、坦率、为了你我能做什么",
      "category_id": 35,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 36,
      "chinese_name": "蒲公英",
      "english_name": "common dandelion",
      "latin_name": "Taraxacum officinale",
      "family": "菊科",
      "genus": "蒲公英属",
      "morphology": "多年生草本植物，株高10-30厘米。根粗壮，木质化。叶基生，莲座状，倒披针形，羽状深裂或倒向羽裂。头状花序单生；舌状花黄色。瘦果有白色冠毛，形似绒球。花期4-10月。",
      "habitat": "原产欧亚大陆，世界各地均有分布。适应性强，耐寒耐热，喜阳光充足。",
      "growth_habit": "花期4-10月，果期5-11月。通过种子和根茎繁殖。",
      "ornamental_value": "童年记忆的象征，金黄色的花朵和白色的绒球都有独特的美。",
      "care_methods": "管理粗放，适应性强。可适当浇水，无需特殊管理。",
      "flower_language": "无法实现的爱、忠诚、温柔",
      "category_id": 36,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 37,
      "chinese_name": "虞美人",
      "english_name": "corn poppy",
      "latin_name": "Papaver rhoeas",
      "family": "罂粟科",
      "genus": "罂粟属",
      "morphology": "一年生草本植物，株高30-60厘米。全株被粗毛。茎直立，有分枝。叶片羽状深裂，裂片线形。花生于长花梗顶端，杯状，红色，基部有黑色斑，花瓣4枚，薄如绸绢。花期5-6月。",
      "habitat": "原产欧亚大陆，喜阳光充足，适应性强，常生于麦田或荒野。",
      "growth_habit": "花期5-6月，果期6-7月。自播繁殖能力强。",
      "ornamental_value": "红花素雅轻盈，在欧洲象征着对逝者的缅怀，是重要的野花代表。",
      "care_methods": "管理粗放，播种直播即可。喜阳光充足，耐贫瘠土壤。",
      "flower_language": "休息、安慰、忘却",
      "category_id": 37,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 38,
      "chinese_name": "仙客来",
      "english_name": "cyclamen",
      "latin_name": "Cyclamen persicum",
      "family": "报春花科",
      "genus": "仙客来属",
      "morphology": "多年生草本植物，株高15-30厘米。块茎扁圆形，球状。叶基生，心形或卵形，边缘有细锯齿，上面深绿色，有银白色斑纹。花单生，下垂，花冠5裂，向后反卷，有红、粉、白等色，喉部颜色较深。花期11月至次年3月。",
      "habitat": "原产地中海地区。喜凉爽湿润的半阴环境，适宜富含腐殖质的土壤。",
      "growth_habit": "花期11月至次年3月，果期4-5月。夏季休眠。",
      "ornamental_value": "花型独特，反卷的花瓣如蝴蝶飞舞，色彩艳丽，是著名的室内盆栽花卉。",
      "care_methods": "生长期保持土壤湿润但避免积水。夏季休眠期停止浇水，置于阴凉处。",
      "flower_language": "内向、羞涩、腼腆、忌惮",
      "category_id": 38,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 39,
      "chinese_name": "水仙",
      "english_name": "daffodil",
      "latin_name": "Narcissus pseudonarcissus",
      "family": "石蒜科",
      "genus": "水仙属",
      "morphology": "多年生草本植物，鳞茎卵球形。叶片宽线形，扁平，深绿色。花茎中空，与叶近等长；花单生或多朵成伞形花序，花冠副花冠呈高脚碟状，黄色或白色，芳香。花期3-4月。",
      "habitat": "原产欧洲和北非洲。喜凉爽湿润阳光充足的环境，耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期3-4月，果期5-6月。通过鳞茎分球或播种繁殖。",
      "ornamental_value": "花色素雅，芳香馥郁，是春天的代表花卉，中国传统名花之一。",
      "care_methods": "种植深度为鳞茎高度的2倍。生长期保持土壤湿润，花后及时追肥。",
      "flower_language": "自尊、独自、流芳",
      "category_id": 39,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 40,
      "chinese_name": "沙漠玫瑰",
      "english_name": "desert-rose",
      "latin_name": "Adenium obesum",
      "family": "夹竹桃科",
      "genus": "沙漠玫瑰属",
      "morphology": "多年生肉质灌木或小乔木，株高1-4米。茎肉质，粗壮，基部膨大。叶片倒卵形或椭圆形，聚集于枝顶，绿色有光泽。花漏斗形，粉红色、红色或白色，5裂，喉部颜色较深。花期4-5月和9-10月。",
      "habitat": "原产非洲热带地区。喜高温干燥阳光充足的环境，耐热耐旱，忌水湿。",
      "growth_habit": "花期4-5月和9-10月，果期夏季。通过播种或扦插繁殖。",
      "ornamental_value": "茎基部膨大如酒瓶状，花色艳丽，是重要的盆景材料。",
      "care_methods": "用排水良好的沙质土壤栽培。控制浇水，保持土壤干燥。冬季注意防寒。",
      "flower_language": "爱你、坚强、珍惜",
      "category_id": 40,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 41,
      "chinese_name": "金盏花",
      "english_name": "english marigold",
      "latin_name": "Calendula officinalis",
      "family": "菊科",
      "genus": "金盏花属",
      "morphology": "一年生草本植物，株高30-60cm。全株被毛。茎直立，有分枝。叶片长圆形至宽披针形，互生。头状花序单生，舌状花黄色或橙黄色，管状花黄色。花期4-9月。",
      "habitat": "原产欧洲南部和非洲北部。喜阳光充足的环境，耐寒耐旱，对土壤要求不严。",
      "growth_habit": "花期4-9月，果期6-10月。生长迅速，适应性强。",
      "ornamental_value": "花色鲜艳，花期长，常用于花坛、花境布置，也是重要的切花和药用植物。",
      "care_methods": "生长期保持土壤湿润但不积水。每月施一次复合肥。注意防治蚜虫。",
      "flower_language": "悲伤、离别、纯洁、友爱",
      "category_id": 41,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 42,
      "chinese_name": "毛地黄",
      "english_name": "foxglove",
      "latin_name": "Digitalis purpurea",
      "family": "玄参科",
      "genus": "毛地黄属",
      "morphology": "二年生或多年生草本植物，株高60-150厘米。茎直立，被绒毛。基生叶卵形或长圆形，边缘有圆齿；茎生叶向上渐小。总状花序顶生，花冠钟状，粉紫色，内有深色斑点，下垂。花期5-6月。",
      "habitat": "原产欧洲。喜半阴湿润环境，耐寒，适宜肥沃排水良好的土壤。",
      "growth_habit": "花期5-6月，果期6-7月。全株有毒，可入药。",
      "ornamental_value": "花序高大，花色艳丽，是良好的林下花卉，但全株有毒。",
      "care_methods": "种植于半阴处，保持土壤湿润。春季施足基肥。注意其毒性，避免误食。",
      "flower_language": "秘密、热爱、不诚实",
      "category_id": 42,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
