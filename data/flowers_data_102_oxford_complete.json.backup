  "flowers": [
    {
      "id": 1,
      "chinese_name": "粉红报春花",
      "english_name": "pink primrose",
      "latin_name": "Primula vulgaris",
      "family": "报春花科",
      "genus": "报春花属",
      "morphology": "多年生草本植物，株高15-30cm。叶片椭圆形或倒卵形，基生莲座状。花单生或双生，花冠漏斗状，粉红色或淡紫色，喉部黄色。花期冬末至春季。",
      "habitat": "喜凉爽湿润环境，怕炎热。适宜生长在富含腐殖质、排水良好的土壤中。原产欧洲温带地区。",
      "growth_habit": "花期1-4月，果期4-6月。喜半阴环境，不耐强光直射。",
      "ornamental_value": "早春开花，花色淡雅，是重要的早春观赏花卉，适合林下或阴处种植。",
      "care_methods": "生长期保持土壤湿润，夏季注意遮阴降温。每月施一次稀薄液肥。",
      "flower_language": "青春、初恋、纯真",
      "category_id": 1,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 2,
      "chinese_name": "硬叶兜兰",
      "english_name": "hard-leaved pocket orchid",
      "latin_name": "Cymbidium mannii",
      "family": "兰科",
      "genus": "兰属",
      "morphology": "多年生附生草本植物。叶片硬革质，线形或带状，深绿色。花葶从叶腋抽出，总状花序着花5-15朵，花黄褐色或绿色，唇瓣白色带紫斑。花期冬季至春季。",
      "habitat": "喜温暖湿润的半阴环境，附生于森林树木或岩石上。适宜排水良好的基质。",
      "growth_habit": "花期11月至次年3月。生长适温15-28℃。",
      "ornamental_value": "叶片挺立翠绿，花朵清香淡雅，是珍贵的观赏兰花。",
      "care_methods": "用疏松透气的植料栽培，浇水遵循见干见湿原则。生长期每月施薄肥一次。",
      "flower_language": "高雅、淡泊、贤德",
      "category_id": 2,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 3,
      "chinese_name": "风铃草",
      "english_name": "Canterbury bells",
      "latin_name": "Campanula medium",
      "family": "桔梗科",
      "genus": "风铃草属",
      "morphology": "二年生草本植物，株高约1米。茎直立粗壮。叶片卵形至倒卵形，边缘有圆齿。总状花序顶生，花冠钟状，5浅裂，蓝紫色、粉色或白色。花期4-6月。",
      "habitat": "原产南欧。喜夏季凉爽、冬季温和的气候。适宜肥沃而排水良好的壤土。",
      "growth_habit": "花期4-6月，果期夏季。两年生栽培，第二年开花。",
      "ornamental_value": "花朵钟状似风铃，色彩明丽素雅，在欧洲十分盛行，是春末夏初常见的观赏花卉。",
      "care_methods": "生长期保持土壤湿润，种植前施足底肥。花后及时修剪残花。",
      "flower_language": "健康、温柔的爱、创造力、远方的祝福",
      "category_id": 3,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 4,
      "chinese_name": "香豌豆",
      "english_name": "sweet pea",
      "latin_name": "Lathyrus odoratus",
      "family": "豆科",
      "genus": "香豌豆属",
      "morphology": "一年生或二年生攀援性草本植物，茎具翅。羽状复叶，末端卷须变态为卷须。花大蝶形，具芳香味，有紫、红、蓝、粉、白等色，并具斑点斑纹。花萼钟状，荚果长圆形。花期初夏。",
      "habitat": "原产意大利。喜冬暖夏无酷暑的气候条件，适宜作二年生花卉栽培。",
      "growth_habit": "花期5-7月。南方可露地越冬，可耐-5℃低温。喜日照充足，也能耐半阴。",
      "ornamental_value": "花型独特，枝条细长柔软，花色丰富且具芳香，是重要的切花材料。",
      "care_methods": "用支架牵引使其攀援。适时摘心促发侧枝。生长期保持土壤湿润，每月施肥一次。",
      "flower_language": "温馨、回忆、感激、离别",
      "category_id": 4,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 5,
      "chinese_name": "金盏花",
      "english_name": "english marigold",
      "latin_name": "Calendula officinalis",
      "family": "菊科",
      "genus": "金盏花属",
      "morphology": "一年生草本植物，株高30-60cm。全株被毛。茎直立，有分枝。叶片长圆形至宽披针形，互生。头状花序单生，舌状花黄色或橙黄色，管状花黄色。花期4-9月。",
      "habitat": "原产欧洲南部和非洲北部。喜阳光充足的环境，耐寒耐旱，对土壤要求不严。",
      "growth_habit": "花期4-9月，果期6-10月。生长迅速，适应性强。",
      "ornamental_value": "花色鲜艳，花期长，常用于花坛、花境布置，也是重要的切花和药用植物。",
      "care_methods": "生长期保持土壤湿润但不积水。每月施一次复合肥。注意防治蚜虫。",
      "flower_language": "悲伤、离别、纯洁、友爱",
      "category_id": 5,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 6,
      "chinese_name": "虎百合",
      "english_name": "tiger lily",
      "latin_name": "Lilium lancifolium",
      "family": "百合科",
      "genus": "百合属",
      "morphology": "多年生球根植物，鳞茎卵圆状扁球形。茎带紫色条纹，具白色毛。叶互生，长圆状披针形至披针形，上部叶腋常具珠芽。花3-20朵，下垂，橙红色，花被片反卷，内面具紫黑色斑点。花期7-8月。",
      "habitat": "几乎遍及我国各地。日本也有分布。生于山野阴坡或林下。",
      "growth_habit": "花期7-8月，果期8-10月。鳞茎可露地自然越冬。",
      "ornamental_value": "花朵大，花色艳丽，花期长，姿态优美，是珍贵的观赏花卉，有百合之冠之称。",
      "care_methods": "种植深度为鳞茎高度的3倍。生长期保持土壤湿润，雨季注意排水。花后及时剪除残花。",
      "flower_language": "百年好合、顺利、心想事成",
      "category_id": 6,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 7,
      "chinese_name": "月兰",
      "english_name": "moon orchid",
      "latin_name": "Phalaenopsis amabilis",
      "family": "兰科",
      "genus": "蝴蝶兰属",
      "morphology": "多年生常绿草本植物。叶片宽厚肉质，扁平，椭圆形或长圆形。花序从叶腋抽出，总状花序或圆锥花序，着花数朵至数十朵。花白色，唇瓣基部有黄色斑纹，形态似蝴蝶。花期春季。",
      "habitat": "原产热带亚洲。附生于森林树木上，喜高温高湿的半阴环境。",
      "growth_habit": "花期3-4月。生长适温22-30℃。",
      "ornamental_value": "花形优雅，洁白如雪，是最受欢迎的年宵花卉之一，素有兰花皇后之称。",
      "care_methods": "用通透性好的植料栽培。浇水见干见湿，保持较高空气湿度。生长期每月施薄肥一次。",
      "flower_language": "高洁、典雅、幸福渐渐到来",
      "category_id": 7,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 8,
      "chinese_name": "天堂鸟",
      "english_name": "bird of paradise",
      "latin_name": "Strelitzia reginae",
      "family": "芭蕉科",
      "genus": "鹤望兰属",
      "morphology": "多年生常绿草本植物，无茎。叶片长圆状披针形，长25-45厘米，宽约10厘米，顶端急尖，基部圆形或楔形。叶柄细长。花数朵生于总花梗上，下托一佛焰苞；佛焰苞舟状，绿色，边紫红；萼片橙黄色；花瓣暗蓝色，箭头状。花期9月至次年6月。",
      "habitat": "原产非洲南部。喜温暖湿润的气候，不耐寒。适宜疏松肥沃的园土。",
      "growth_habit": "花期9月至次年6月。生长适温3-10月为18-24℃，10月至次年3月为13-18℃。",
      "ornamental_value": "花形奇特，色彩艳丽，姿态优美，是珍贵的切花和盆景材料。",
      "care_methods": "生长期保持土壤湿润，经常向叶面喷水。每月施复合肥一次。越冬温度不低于5℃。",
      "flower_language": "自由、幸福、潇洒、吉祥",
      "category_id": 8,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 9,
      "chinese_name": "乌头",
      "english_name": "monkshood",
      "latin_name": "Aconitum carmichaelii",
      "family": "毛茛科",
      "genus": "乌头属",
      "morphology": "多年生草本植物，块根倒圆锥形。茎高60-150厘米，上部有反曲柔毛。叶片薄革质或纸质，五角形，基部浅心形三裂。中央全裂片宽菱形。花序顶生，总状花序；萼片蓝紫色，外有细柔毛，上萼片高盔状。花期9-10月。",
      "habitat": "分布于中国大部分地区。喜凉爽湿润环境，耐寒。适宜富含腐殖质的土壤。",
      "growth_habit": "花期9-10月，果期10-11月。块根入药，有剧毒。",
      "ornamental_value": "花形独特，蓝紫色花序亭亭玉立，具有较高的观赏价值，可用于花境配置。",
      "care_methods": "喜半阴环境，夏季需遮阴。保持土壤湿润但不积水。需注意其毒性。",
      "flower_language": "危险、谨慎、敬意",
      "category_id": 9,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 10,
      "chinese_name": "球蓟",
      "english_name": "globe thistle",
      "latin_name": "Echinops ritro",
      "family": "菊科",
      "genus": "球蓟属",
      "morphology": "多年生草本植物，株高50-100厘米。茎直立，有分枝，具白色绵毛。叶片羽状深裂，裂片有刺，上面绿色，下面白色被绒毛。头状花序球形，直径2-4厘米，全部为管状花，蓝紫色。花期7-8月。",
      "habitat": "原产欧洲和西亚。性强健，耐寒耐旱，喜阳光充足和排水良好的土壤。",
      "growth_habit": "花期7-8月，果期9月。适应性强，繁殖容易。",
      "ornamental_value": "花序球形，蓝紫色别致，是很好的蜜源植物和干花材料，也可用于花境布置。",
      "care_methods": "栽培管理粗放。种植前施足底肥，生长期适当浇水即可。",
      "flower_language": "独立、勇敢、防御",
      "category_id": 10,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 11,
      "chinese_name": "红掌",
      "english_name": "anthurium",
      "latin_name": "Anthurium andraeanum",
      "family": "天南星科",
      "genus": "红掌属",
      "morphology": "多年生常绿草本植物。叶片心形或卵心形，绿色，革质。花序为肉穗花序，佛焰苞心形，红色、粉红色或白色，具光泽。花期全年。",
      "habitat": "原产热带美洲。喜高温高湿的半阴环境，适宜疏松肥沃、排水良好的土壤。",
      "growth_habit": "花期全年，盛花期夏秋季。生长适温22-28℃。",
      "ornamental_value": "佛焰苞色彩艳丽，形态独特，是重要的热带观花观叶植物，适合盆栽或切花。",
      "care_methods": "生长期保持土壤湿润，定期向叶面喷水。每月施稀薄液肥一次。避免阳光直射。",
      "flower_language": "热情、热心、大展宏图",
      "category_id": 11,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 12,
      "chinese_name": "洋蓟",
      "english_name": "artichoke",
      "latin_name": "Cynara cardunculus var. scolymus",
      "family": "菊科",
      "genus": "菜蓟属",
      "morphology": "多年生草本植物，株高1-2米。茎粗壮直立。叶片大型，羽状深裂，灰绿色，被绒毛。头状花序大型，球形，总苞片多层，内层肉质可食。花紫蓝色。花期6-7月。",
      "habitat": "原产地中海地区。喜凉爽干燥气候，耐寒，适宜肥沃深厚排水良好的土壤。",
      "growth_habit": "花期6-7月，果期7-8月。以地下茎繁殖为主。",
      "ornamental_value": "株型美观，花序紫蓝艳丽，可作观赏植物栽培，也是重要的蔬菜作物。",
      "care_methods": "种植前施足基肥，生长期保持土壤湿润。及时采收花头以促进分枝。",
      "flower_language": "谜样、耐心、期待",
      "category_id": 12,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 13,
      "chinese_name": "杜鹃花",
      "english_name": "azalea",
      "latin_name": "Rhododendron simsii",
      "family": "杜鹃花科",
      "genus": "杜鹃花属",
      "morphology": "落叶或常绿灌木，株高1-3米。叶片椭圆形或卵形，边缘有细锯齿。花2-6朵簇生枝顶，花冠漏斗形，红色、粉红色或白色，有裂片5。花期4-5月。",
      "habitat": "原产中国，喜酸性土壤，多生于海拔500-1200米的山坡林下或灌木丛中。",
      "growth_habit": "花期4-5月，果期6-8月。喜酸性、疏松排水良好的土壤。",
      "ornamental_value": "花色艳丽，花期长，是中国十大名花之一，有\"花中西施\"之美誉。",
      "care_methods": "喜酸性水，可用矾肥水浇灌。夏季遮阴，冬季保暖。生长期每月施稀薄矾肥水。",
      "flower_language": "鸿运当头、吉祥、美好",
      "category_id": 13,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 14,
      "chinese_name": "空气凤梨",
      "english_name": "ball moss",
      "latin_name": "Tillandsia recurvata",
      "family": "凤梨科",
      "genus": "铁兰属",
      "morphology": "多年生常绿草本植物，附生。叶片线形，灰绿色，密生成球状或莲座状。叶片基部膨大，可储水。花小，单生或成对生于叶丛中，黄绿色或灰绿色。",
      "habitat": "原产美洲热带和亚热带地区。附生于树木、电线或岩石上，喜阳光充足的环境。",
      "growth_habit": "花期不定，通常在温暖季节开花。通过种子或吸芽繁殖。",
      "ornamental_value": "形态独特，适合做空气凤梨观赏，也可用于垂直绿化的材料。",
      "care_methods": "可直接固定于树枝或石头上养护。每天喷雾浇水，或每周浸水一次。",
      "flower_language": "独立、坚强、生命力",
      "category_id": 14,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 15,
      "chinese_name": "桔梗",
      "english_name": "balloon flower",
      "latin_name": "Platycodon grandiflorus",
      "family": "桔梗科",
      "genus": "桔梗属",
      "morphology": "多年生草本植物，株高30-80厘米。根胡萝卜状。茎直立。叶片卵形至披针形，边缘有锯齿。花单生或数朵生于茎顶，花冠钟状，蓝色、蓝紫色或白色，5裂。花期7-9月。",
      "habitat": "原产中国、朝鲜半岛和日本。喜阳光充足，耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期7-9月，果期9-10月。根可入药，有宣肺、化痰、利咽的功效。",
      "ornamental_value": "花形独特，形似气球，色彩雅致，是良好的观赏花卉和药材。",
      "care_methods": "生长期保持土壤湿润。春季施足基肥，花前追施磷钾肥。",
