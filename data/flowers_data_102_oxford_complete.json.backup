    {
      "id": 17,
      "chinese_name": "须鸢尾",
      "english_name": "bearded iris",
      "latin_name": "Iris germanica",
      "family": "鸢尾科",
      "genus": "鸢尾属",
      "morphology": "多年生草本植物，株高60-100厘米。根茎粗壮。叶剑形，基部套叠状。花茎中空，花大形，垂瓣基部有须毛状髯毛，有紫、白、黄、粉等多种颜色。花期4-5月。",
      "habitat": "原产欧洲。喜阳光充足，耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期4-5月，果期5-6月。通过分株繁殖为主。",
      "ornamental_value": "花型优雅，色彩丰富，是重要的观赏花卉和香料植物。",
      "care_methods": "种植深度宜浅，根茎顶部露出土面。生长期适当浇水，花后及时分株。",
      "flower_language": "智慧、勇气、信仰",
      "category_id": 17,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 18,
      "chinese_name": "香蜂草",
      "english_name": "bee balm",
      "latin_name": "Monarda didyma",
      "family": "唇形科",
      "genus": "美洲红薄荷属",
      "morphology": "多年生草本植物，株高60-120厘米。茎直立，四棱形。叶片卵状披针形，边缘有锯齿。头状花序顶生，花冠二唇形，红色、粉红色或紫色。花期7-9月。",
      "habitat": "原产北美。喜阳光充足或半阴，耐寒，适应性强，适宜湿润肥沃的土壤。",
      "growth_habit": "花期7-9月，果期9-10月。通过分株或播种繁殖。",
      "ornamental_value": "花序鲜艳，色彩丰富，是良好的蜜源植物和观赏花卉。",
      "care_methods": "生长期保持土壤湿润。春季分株更新，夏季注意防治锈病。",
      "flower_language": "活力、热情、关怀",
      "category_id": 18,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
