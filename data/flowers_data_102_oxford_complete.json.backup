    {
      "id": 55,
      "chinese_name": "帝王花",
      "english_name": "king protea",
      "latin_name": "Protea cynaroides",
      "family": "山龙眼科",
      "genus": "帝王花属",
      "morphology": "常绿灌木，株高1-3米。叶片椭圆形或卵形，革质，深绿色，有叶柄。花序大型，头状花序，径可达30厘米；总苞片多层，革质，粉红色至深红色，排列如花瓣；花心由许多小花组成，如一个精致的杯子。花期4-9月。",
      "habitat": "原产南非。喜阳光充足，温暖干燥气候，耐热耐旱，适宜排水良好的酸性土壤。",
      "growth_habit": "花期4-9月，果期6-10月。通过播种或扦插繁殖。",
      "ornamental_value": "花序巨大华丽，是南非的国花，也是世界著名的切花材料。",
      "care_methods": "用排水良好的酸性土壤栽培。控制浇水，保持土壤干燥。",
      "flower_language": "华丽、荣耀、胜利",
      "category_id": 55,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
