    {
      "id": 72,
      "chinese_name": "木槿",
      "english_name": "hibiscus",
      "latin_name": "Hibiscus rosa-sinensis",
      "family": "锦葵科",
      "genus": "木槿属",
      "morphology": "常绿灌木或小乔木，株高1-5米。叶片卵形或椭圆状披针形，边缘有锯齿，绿色有光泽。花大，单生或成伞房花序生于枝顶；花冠漏斗状，5裂，有红、粉、橙、黄、白等色及重瓣品种。花期5-10月。",
      "habitat": "原产中国和东南亚。喜阳光充足，温暖湿润气候，耐热不耐寒。",
      "growth_habit": "花期5-10月，果期8-11月。通过扦插或播种繁殖。",
      "ornamental_value": "花大色艳，是热带重要的观赏花卉，夏威夷的州花。",
      "care_methods": "生长期保持土壤湿润。春季修剪促发新枝。花前增施磷钾肥。",
      "flower_language": "热情、勇敢、美丽",
      "category_id": 72,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
      "id": 73,
