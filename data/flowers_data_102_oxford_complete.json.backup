    {
      "id": 53,
      "chinese_name": "朱顶红",
      "english_name": "hippeastrum",
      "latin_name": "Hippeastrum spp.",
      "family": "石蒜科",
      "genus": "朱顶红属",
      "morphology": "多年生草本植物，鳞茎大型，球形。叶片宽带状，深绿色，基生。花茎中空，粗壮；伞形花序顶生，着花2-6朵；花大，漏斗状，有红、粉、白、橙等色，具条纹或斑点。花期4-6月。",
      "habitat": "原产热带美洲。喜温暖阳光充足的环境，耐热不耐寒，适宜排水良好的土壤。",
      "growth_habit": "花期4-6月，果期5-7月。通过鳞茎分球或播种繁殖。",
      "ornamental_value": "花大色艳，色彩丰富，是重要的盆栽和切花花卉。",
      "care_methods": "种植深度为鳞茎的1/3。生长期保持土壤湿润，花后及时施肥。",
      "flower_language": "追求、渴望、勇敢尝试",
      "category_id": 53,
      "image_url": "",
      "data_source": "Oxford 102数据集",
      "collected_date": "2024-01-15"
    },
    {
